# ── seats.aero Pro API ─────────────────────────────────────────────────────────
# Generate your key at: https://seats.aero/settings (API tab)
SEATS_AERO_API_KEY=your_api_key_here

# ── Pushover alerts (optional) ────────────────────────────────────────────────
# Create an app at https://pushover.net/apps/build, then:
PUSHOVER_APP_TOKEN=
PUSHOVER_USER_KEY=

# ── Email alerts (optional) ────────────────────────────────────────────────────
# Leave SMTP_HOST blank to disable email. macOS notifications are always used
# when running on a Mac. Set DISABLE_MACOS_NOTIFICATIONS=true in Docker/headless.

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL=

# ── Environment flags ──────────────────────────────────────────────────────────
# Set to true when running in Docker or any headless environment where
# osascript is not available.
DISABLE_MACOS_NOTIFICATIONS=false
